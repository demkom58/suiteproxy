# SuiteProxy Configuration
# Copy this to .env and fill in values

# API key for authenticating ALL access to the proxy.
# Protects: dashboard, account management, /api/v1/* endpoints, extension sync.
# If not set, the proxy runs in open access mode (no auth required).
# The same key is used everywhere — dashboard login, extension config, Bearer token.
PROXY_API_KEY=your-secret-api-key-here
